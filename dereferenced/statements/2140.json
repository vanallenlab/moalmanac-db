  "indication": {
    "id": "ind:hc.lynparza:6",
    "indication": "LYNPARZA is indicated in combination with abiraterone and prednisone or prednisolone for the treatment of adult patients with deleterious or suspected deleterious germline and/or somatic BRCA mutated metastatic castration resistant prostate cancer (mCRPC) in whom chemotherapy is not clinically indicated. BRCA mutation must be confirmed before LYNPARZA treatment is initiated.",
    "initial_approval_date": null,
    "initial_approval_url": null,
